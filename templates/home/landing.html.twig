    <div class="nav-mobile-overlay" id="nav-mobile-overlay">
        <button class="nav-overlay-close" id="nav-overlay-close" aria-label="{{ 'common.cancel'|trans }}">
            <i class="fas fa-times"></i>
        </button>
        <a href="#features" class="nav-link-item">{{ 'landing.nav.features'|trans }}</a>
        <a href="#ai" class="nav-link-item">{{ 'landing.nav.ai'|trans }}</a>
        <a href="#maps" class="nav-link-item">{{ 'landing.nav.maps'|trans }}</a>
        <a href="#warehouse" class="nav-link-item">{{ 'landing.nav.warehouse'|trans }}</a>
        <a href="#business" class="nav-link-item">{{ 'landing.nav.business'|trans }}</a>
        <a href="{{ main_url }}" class="btn-primary">{{ 'common.launch_service'|trans }}</a>
    </div>

    <button id="scroll-top" class="scroll-top-btn" aria-label="Наверх" title="Наверх">
        <i class="fas fa-chevron-up"></i>
    </button>

    <script>
        const nav = document.querySelector('nav');
        const scrollBtn = document.getElementById('scroll-top');
        const burger = document.getElementById('burger');
        const overlay = document.getElementById('nav-mobile-overlay');

        const navLinkItems = document.querySelectorAll('.nav-links a.nav-link-item');
        const sections = ['features', 'ai', 'maps', 'warehouse', 'business'].map(id => document.getElementById(id)).filter(Boolean);

        const updateActiveNav = () => {
            const scrollY = window.scrollY;
            let current = '';
            sections.forEach(section => {
                if (scrollY >= section.offsetTop - 120) {
                    current = section.id;
                }
            });
            navLinkItems.forEach(link => {
                link.classList.toggle('nav-active', link.getAttribute('href') === '#' + current);
            });
        };

        window.addEventListener('scroll', () => {
            nav.classList.toggle('nav--scrolled', window.scrollY > 60);
            scrollBtn.classList.toggle('scroll-top-btn--visible', window.scrollY > 400);
            updateActiveNav();
        });

        scrollBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        const closeOverlay = () => {
            overlay.classList.remove('nav-mobile-overlay--open');
            burger.classList.remove('burger--open');
            burger.setAttribute('aria-expanded', 'false');
            document.body.style.overflow = '';
        };

        burger.addEventListener('click', () => {
            const isOpen = overlay.classList.toggle('nav-mobile-overlay--open');
            burger.classList.toggle('burger--open', isOpen);
            burger.setAttribute('aria-expanded', isOpen);
            document.body.style.overflow = isOpen ? 'hidden' : '';
        });

        document.getElementById('nav-overlay-close').addEventListener('click', closeOverlay);

        overlay.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', closeOverlay);
        });
    </script>
