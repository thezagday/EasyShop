{# Sets _locale cookie (optional shared domain) and reloads — no /_locale= URL query #}
<div class="language-switcher-twig" role="group" aria-label="{{ 'language.switcher'|trans }}">
    {% set current_locale = app.request.locale %}
    {% set locales = [
        {'code': 'pl', 'name': 'PL', 'flag': '&#x1F1F5;&#x1F1F1;'},
        {'code': 'en', 'name': 'EN', 'flag': '🇺🇸'}
    ] %}

    {% for locale in locales %}
        <button type="button"
                class="lang-link{% if current_locale == locale.code %} active{% endif %}"
                data-locale="{{ locale.code }}"
                title="{{ locale.name }}">
            <span class="flag">{{ locale.flag|raw }}</span>
            <span class="name">{{ locale.name }}</span>
        </button>
    {% endfor %}
</div>

<style>
.language-switcher-twig {
    display: inline-flex;
    gap: 10px;
    align-items: center;
}
.language-switcher-twig .lang-link {
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 2px 6px;
    border-radius: 4px;
    transition: all 0.2s;
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: inherit;
}
.language-switcher-twig .lang-link:hover {
    opacity: 1;
    background: rgba(255,255,255,0.1);
}
.language-switcher-twig .lang-link.active {
    opacity: 1;
    font-weight: bold;
    background: rgba(255,255,255,0.2);
}
nav .language-switcher-twig .lang-link {
    color: #fff;
}
.bg-white .language-switcher-twig .lang-link {
    color: #333;
}
</style>
<script>
(function () {
    document.querySelectorAll('.language-switcher-twig [data-locale]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var lng = btn.getAttribute('data-locale');
            var localeCookie = '_locale=' + encodeURIComponent(lng) + ';path=/;max-age=31536000;SameSite=Lax';
            document.cookie = localeCookie;
            location.reload();
        });
    });
})();
</script>
